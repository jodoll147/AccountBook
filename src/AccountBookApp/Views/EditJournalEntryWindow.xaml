<Window x:Class="AccountBookApp.Views.EditJournalEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="거래 수정"
        Width="760"
        MinWidth="760"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Border Margin="18"
                Padding="24"
                Background="{DynamicResource PaperBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="거래 수정" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SectionTitleStyle}"
                               Text="{Binding EntryEditSummaryText}" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="아래 항목을 수정한 뒤 저장하면 최근 거래 목록에 바로 반영됩니다."
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="18,16"
                            Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="출금 계정" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding EditSelectedFromAccount.DisplayName}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource SubtleBodyStyle}"
                                       Text="{Binding EditSelectedFromAccount.Description}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="18,16"
                            Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="입금 계정" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding EditSelectedToAccount.DisplayName}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource SubtleBodyStyle}"
                                       Text="{Binding EditSelectedToAccount.Description}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="출금 계정 선택" />
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding ActiveAccounts}"
                                  SelectedItem="{Binding EditSelectedFromAccount, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource ComboTemplateTextStyle}" Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="입금 계정 선택" />
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding ActiveAccounts}"
                                  SelectedItem="{Binding EditSelectedToAccount, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource ComboTemplateTextStyle}" Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="날짜" />
                        <DatePicker Margin="0,8,0,0"
                                    SelectedDate="{Binding EditEntryDate, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="금액" />
                        <TextBox Margin="0,8,0,0"
                                 Text="{Binding EditAmountText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="3">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="거래명" />
                        <TextBox Margin="0,8,0,0"
                                 Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.ColumnSpan="3">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="메모" />
                        <TextBox Margin="0,8,0,0"
                                 MinHeight="110"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding EditMemo, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="6"
                        Padding="14,12"
                        Background="{DynamicResource WarningBackgroundBrush}"
                        BorderBrush="{DynamicResource WarningBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding HasEditValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Foreground="{DynamicResource WarningTextBrush}"
                               Text="{Binding EditValidationMessage}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Height="44"
                            Click="SaveButton_Click"
                            Command="{Binding SaveEditedEntryCommand}"
                            Content="수정 저장"
                            IsDefault="True" />

                    <Button Grid.Column="2"
                            Height="44"
                            Background="{DynamicResource SecondaryButtonBrush}"
                            BorderBrush="{DynamicResource SecondaryButtonBorderBrush}"
                            Foreground="{DynamicResource SecondaryButtonTextBrush}"
                            Click="CancelButton_Click"
                            Command="{Binding CancelEntryEditCommand}"
                            Content="취소"
                            IsCancel="True" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
