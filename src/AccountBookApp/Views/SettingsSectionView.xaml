<UserControl x:Class="AccountBookApp.Views.SettingsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="AccountCardTemplate">
            <Border Margin="0,0,0,10"
                    Padding="16,14"
                    Background="{DynamicResource InputBackgroundBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    ContextMenuOpening="AccountCard_ContextMenuOpening">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="수정" Click="EditAccountMenuItem_Click" />
                        <MenuItem Header="삭제" Click="ArchiveAccountMenuItem_Click" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource SubtleBodyStyle}"
                                   Text="{Binding Description}"
                                   TextWrapping="Wrap" />
                        <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                            <Button Style="{StaticResource InlineActionButtonStyle}"
                                    Click="InlineEditAccountButton_Click"
                                    Content="수정" />
                            <Button Margin="8,0,0,0"
                                    Style="{StaticResource InlineDangerActionButtonStyle}"
                                    Click="InlineDeleteAccountButton_Click"
                                    Content="삭제" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Top"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="{Binding Code}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid MinHeight="1660">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Padding="22"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="데이터 관리" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="초기 샘플 거래나 입력한 기록을 비우고 싶을 때 사용합니다. 계정 분류는 그대로 유지됩니다."
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Width="168"
                        Height="42"
                        VerticalAlignment="Center"
                        Background="{DynamicResource SecondaryButtonBrush}"
                        BorderBrush="{DynamicResource SecondaryButtonBorderBrush}"
                        Foreground="{DynamicResource SecondaryButtonTextBrush}"
                        Command="{Binding ResetDemoDataCommand}"
                        Content="데모 데이터 삭제" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                Padding="22"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="테마" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="다크, 밝은 톤, 연분홍 톤 중에서 원하는 분위기를 고르면 화면 전체에 즉시 적용됩니다."
                               TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="화면 테마" />
                    <ComboBox Margin="0,10,0,0"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedThemeOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource ComboTemplateTextStyle}" Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Grid.Column="0"
                Padding="22"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="자산" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="현금성 자산과 생활 자금을 관리하는 계정입니다."
                               TextWrapping="Wrap" />
                </StackPanel>
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding AssetAccounts}"
                              ItemTemplate="{StaticResource AccountCardTemplate}" />
                <Button Grid.Row="4"
                        Height="40"
                        Command="{Binding NewAssetAccountCommand}"
                        Content="+ 자산 계정 추가" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Grid.Column="2"
                Padding="22"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="투자" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="주식, ETF, 펀드, 코인처럼 투자 성격의 자산을 따로 관리합니다."
                               TextWrapping="Wrap" />
                </StackPanel>
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding InvestmentAccounts}"
                              ItemTemplate="{StaticResource AccountCardTemplate}" />
                <Button Grid.Row="4"
                        Height="40"
                        Command="{Binding NewInvestmentAccountCommand}"
                        Content="+ 투자 계정 추가" />
            </Grid>
        </Border>

        <Border Grid.Row="6"
                Grid.Column="0"
                Padding="22"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="부채" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="카드값, 대출처럼 상환이 필요한 계정을 관리합니다."
                               TextWrapping="Wrap" />
                </StackPanel>
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding LiabilityAccounts}"
                              ItemTemplate="{StaticResource AccountCardTemplate}" />
                <Button Grid.Row="4"
                        Height="40"
                        Command="{Binding NewLiabilityAccountCommand}"
                        Content="+ 부채 계정 추가" />
            </Grid>
        </Border>

        <Border Grid.Row="6"
                Grid.Column="2"
                Padding="22"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="지출" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="생활비, 교통비, 주거비처럼 소비성 항목을 관리합니다."
                               TextWrapping="Wrap" />
                </StackPanel>
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding ExpenseAccounts}"
                              ItemTemplate="{StaticResource AccountCardTemplate}" />
                <Button Grid.Row="4"
                        Height="40"
                        Command="{Binding NewExpenseAccountCommand}"
                        Content="+ 지출 계정 추가" />
            </Grid>
        </Border>

        <Border Grid.Row="8"
                Grid.Column="0"
                Padding="22"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="순자산" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="기초 자본이나 누적 순자산처럼 기준이 되는 계정입니다."
                               TextWrapping="Wrap" />
                </StackPanel>
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding EquityAccounts}"
                              ItemTemplate="{StaticResource AccountCardTemplate}" />
                <Button Grid.Row="4"
                        Height="40"
                        Command="{Binding NewEquityAccountCommand}"
                        Content="+ 순자산 계정 추가" />
            </Grid>
        </Border>

        <Border Grid.Row="8"
                Grid.Column="2"
                Padding="22"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="수익" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="급여와 기타 수익처럼 현금이 유입되는 계정을 관리합니다."
                               TextWrapping="Wrap" />
                </StackPanel>
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding RevenueAccounts}"
                              ItemTemplate="{StaticResource AccountCardTemplate}" />
                <Button Grid.Row="4"
                        Height="40"
                        Command="{Binding NewRevenueAccountCommand}"
                        Content="+ 수익 계정 추가" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
