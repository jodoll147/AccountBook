<UserControl x:Class="AccountBookApp.Views.AnalysisSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="AnalysisTabButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InsightCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,16,0" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style x:Key="SignedValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PositiveValueBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPositiveBalance}" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource NegativeValueBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ComparisonBarFillStyle" TargetType="Border">
            <Setter Property="Height" Value="12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource PositiveValueBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPositiveBalance}" Value="False">
                    <Setter Property="Background" Value="{DynamicResource NegativeValueBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="MonthSelectorComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="228" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
        </Style>
        <Style x:Key="AnalysisFilterComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="138" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="{DynamicResource InputContrastTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid MinHeight="1220">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="18" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding ShowNetAssetAnalysisTabCommand}" Content="순자산">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AnalysisTabButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNetAssetAnalysisTabSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Margin="8,0,0,0" Command="{Binding ShowExpenseAnalysisTabCommand}" Content="지출">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AnalysisTabButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpenseAnalysisTabSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Margin="8,0,0,0" Command="{Binding ShowAccountStatusAnalysisTabCommand}" Content="계정 상태">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AnalysisTabButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAccountStatusAnalysisTabSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <DatePicker Width="172" SelectedDate="{Binding AnalysisStartDate, Mode=TwoWay}" />
                        <TextBlock Margin="10,0" VerticalAlignment="Center" Style="{StaticResource SubtleBodyStyle}" Text="~" />
                        <DatePicker Width="172" SelectedDate="{Binding AnalysisEndDate, Mode=TwoWay}" />
                        <Button Width="86" Margin="10,0,0,0" Command="{Binding RefreshAnalysisCommand}" Content="검색" />
                        <ComboBox Margin="10,0,0,0" Style="{StaticResource AnalysisFilterComboBoxStyle}" ItemsSource="{Binding AccountStatusPeriodOptions}" SelectedItem="{Binding SelectedAccountStatusPeriodOption, Mode=TwoWay}" Visibility="{Binding IsAccountStatusAnalysisTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource ComboTemplateTextStyle}" Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="{Binding AnalysisTabDescription}" />
                    <Border Grid.Column="1"
                            Height="44"
                            Padding="12,6"
                            Background="{DynamicResource HoverBrush}"
                            CornerRadius="14"
                            VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SubtleBodyStyle}"
                                   Text="{Binding AnalysisRangeSummary}"
                                   TextAlignment="Center" />
                    </Border>
                    <Border Grid.Column="2"
                            Height="44"
                            Margin="8,0,0,0"
                            Padding="12,6"
                            Background="{DynamicResource HoverBrush}"
                            CornerRadius="14"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsAccountStatusAnalysisTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SubtleBodyStyle}"
                                   Text="{Binding AccountStatusRangeSummary}"
                                   TextAlignment="Center" />
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="14,12" Background="{DynamicResource WarningBackgroundBrush}" BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1" CornerRadius="16" Visibility="{Binding HasAnalysisMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Foreground="{DynamicResource WarningTextBrush}" Text="{Binding AnalysisMessage}" TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="4" Visibility="{Binding IsNetAssetAnalysisTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="22" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <ComboBox Style="{StaticResource MonthSelectorComboBoxStyle}" ItemsSource="{Binding AnalysisMonths}" SelectedItem="{Binding SelectedAnalysisMonth, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="17"
                                                   FontWeight="SemiBold"
                                                   Style="{StaticResource ComboTemplateTextStyle}"
                                                   Text="{Binding StringFormat={}{0:yyyy년 M월}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Margin="0,16,0,0" Style="{StaticResource SectionTitleStyle}" Text="순자산 흐름" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="자산과 투자에서 부채를 뺀 순자산의 흐름을 월 기준으로 확인합니다." TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Top" Style="{StaticResource MetricValueStyle}" Text="{Binding AnalysisNetAssetSummary}" />
                    </Grid>
                    <Border Grid.Row="2" MinHeight="286" Background="{DynamicResource PanelRaisedBrush}" CornerRadius="20">
                        <Grid Margin="18,14,18,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="220" />
                                <RowDefinition Height="34" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Width="760" HorizontalAlignment="Left" ClipToBounds="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{DynamicResource ChartGridBrush}" BorderThickness="0,0,0,1" />
                                <Border Grid.Row="1" BorderBrush="{DynamicResource ChartGridBrush}" BorderThickness="0,0,0,1" />
                                <Border Grid.Row="2" BorderBrush="{DynamicResource ChartGridBrush}" BorderThickness="0,0,0,1" />
                                <Polyline Stroke="{DynamicResource NetAssetLineBrush}" StrokeThickness="8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.18" Points="{Binding NetAssetLinePoints}" />
                                <Polyline Stroke="{DynamicResource NetAssetLineBrush}" StrokeThickness="4" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Points="{Binding NetAssetLinePoints}" />
                                <ItemsControl ItemsSource="{Binding NetAssetChartPoints}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="760" Height="220" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}" />
                                            <Setter Property="Canvas.Top" Value="{Binding CanvasTop}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="28" Height="28" Background="Transparent" Cursor="Hand" ToolTipService.InitialShowDelay="80" ToolTipService.ShowDuration="60000">
                                                <Border.ToolTip>
                                                    <ToolTip Placement="Mouse" HorizontalOffset="14" VerticalOffset="14">
                                                        <StackPanel>
                                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding DateText}" />
                                                            <TextBlock Margin="0,4,0,0" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding AmountText}" />
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Border.ToolTip>
                                                <Grid>
                                                    <Ellipse Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="#33BE5AF2" />
                                                    <Ellipse Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource NetAssetLineBrush}" Stroke="{DynamicResource PaperBackgroundBrush}" StrokeThickness="1.6" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                            <ItemsControl Grid.Row="1" Width="760" HorizontalAlignment="Left" ItemsSource="{Binding AnalysisLabels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="760" Height="34" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        <Setter Property="Canvas.Top" Value="8" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding Text}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <ItemsControl Grid.Row="2" ItemsSource="{Binding NetAssetHighlights}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource InsightCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding Title}" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource MetricValueStyle}" Text="{Binding Value}" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource SubtleBodyStyle}" Text="{Binding Hint}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Padding="20" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="순자산 비교" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="시작 순자산, 종료 순자산, 순증감을 막대 길이로 비교해 증가와 감소를 빠르게 읽을 수 있습니다." TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Row="2" Padding="16" Background="{DynamicResource PanelRaisedBrush}" CornerRadius="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding NetAssetTrendHeadline}" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="{Binding NetAssetTrendHint}" TextWrapping="Wrap" />
                                </StackPanel>
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding NetAssetComparisonBars}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="14,12" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="16">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="12" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                                                            <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="{Binding Caption}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource SignedValueTextStyle}" Text="{Binding AmountText}" />
                                                    </Grid>
                                                    <Border Grid.Row="2" Height="12" Background="{DynamicResource HoverBrush}" CornerRadius="6">
                                                        <Border Width="{Binding BarWidth}" HorizontalAlignment="Left" Style="{StaticResource ComparisonBarFillStyle}" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Padding="20" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="순자산 영향 계정" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="자산, 투자, 부채 중에서 현재 순자산에 영향이 큰 계정을 모아 보여줍니다." TextWrapping="Wrap" />
                        </StackPanel>
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding NetAssetFocusAccounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="14,12" Background="{DynamicResource PanelRaisedBrush}" CornerRadius="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding Icon}" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="{Binding TypeLabel}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource SignedValueTextStyle}" Text="{Binding BalanceText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="4" Visibility="{Binding IsExpenseAnalysisTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="22" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="지출 추이" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="날짜별 지출 흐름과 큰 지출이 발생한 시점을 한눈에 확인합니다." TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Top" Style="{StaticResource MetricValueStyle}" Text="{Binding AnalysisExpenseSummary}" />
                    </Grid>
                    <Border Grid.Row="2" MinHeight="286" Background="{DynamicResource PanelRaisedBrush}" CornerRadius="20">
                        <Grid Margin="18,14,18,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="220" />
                                <RowDefinition Height="34" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Width="760" HorizontalAlignment="Left" ClipToBounds="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{DynamicResource ChartGridBrush}" BorderThickness="0,0,0,1" />
                                <Border Grid.Row="1" BorderBrush="{DynamicResource ChartGridBrush}" BorderThickness="0,0,0,1" />
                                <Polyline Stroke="{DynamicResource ExpenseLineBrush}" StrokeThickness="8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.16" Points="{Binding ExpenseLinePoints}" />
                                <Polyline Stroke="{DynamicResource ExpenseLineBrush}" StrokeThickness="4" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Points="{Binding ExpenseLinePoints}" />
                                <ItemsControl ItemsSource="{Binding ExpenseChartPoints}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="760" Height="220" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}" />
                                            <Setter Property="Canvas.Top" Value="{Binding CanvasTop}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="28" Height="28" Background="Transparent" Cursor="Hand" ToolTipService.InitialShowDelay="80" ToolTipService.ShowDuration="60000">
                                                <Border.ToolTip>
                                                    <ToolTip Placement="Mouse" HorizontalOffset="14" VerticalOffset="14">
                                                        <StackPanel>
                                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding DateText}" />
                                                            <TextBlock Margin="0,4,0,0" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding AmountText}" />
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Border.ToolTip>
                                                <Grid>
                                                    <Ellipse Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="#334DA3FF" />
                                                    <Ellipse Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource ExpenseLineBrush}" Stroke="{DynamicResource PaperBackgroundBrush}" StrokeThickness="1.6" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                            <ItemsControl Grid.Row="1" Width="760" HorizontalAlignment="Left" ItemsSource="{Binding AnalysisLabels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="760" Height="34" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        <Setter Property="Canvas.Top" Value="8" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding Text}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <ItemsControl Grid.Row="2" ItemsSource="{Binding ExpenseHighlights}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource InsightCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding Title}" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource MetricValueStyle}" Text="{Binding Value}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource SubtleBodyStyle}" Text="{Binding Hint}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Padding="20" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="지출 비중" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="어디에 가장 많이 쓰는지 도넛 차트와 항목 목록으로 함께 확인합니다." TextWrapping="Wrap" />
                        </StackPanel>
                        <Grid Grid.Row="2" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="232" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="192" Height="192" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Ellipse Width="164" Height="164" Fill="{DynamicResource PanelRaisedBrush}" Stroke="{DynamicResource LineBrush}" StrokeThickness="1" />
                                <ItemsControl ItemsSource="{Binding ExpenseDonutSlices}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="192" Height="192" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding Geometry}" Fill="{Binding Fill}" Stroke="{DynamicResource PanelRaisedBrush}" StrokeThickness="4">
                                                <Path.ToolTip>
                                                    <ToolTip>
                                                        <StackPanel>
                                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding AmountText}" />
                                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding ShareText}" />
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Path.ToolTip>
                                            </Path>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Width="92" Height="92" Background="{DynamicResource HoverBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="46">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center" Style="{StaticResource MetricLabelStyle}" Text="{Binding ExpenseDonutCenterTitle}" />
                                        <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Text="{Binding ExpenseDonutCenterValue}" />
                                        <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" Style="{StaticResource SubtleBodyStyle}" Text="{Binding ExpenseDonutCenterSubtitle}" TextAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <ItemsControl Grid.Column="2" ItemsSource="{Binding ExpenseDonutSlices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Padding="14,12" Background="{DynamicResource PanelRaisedBrush}" CornerRadius="16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="12" Height="12" VerticalAlignment="Top" Background="{Binding Fill}" CornerRadius="6" />
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                    <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="{Binding TransactionCountText}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                                                    <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold" Text="{Binding AmountText}" />
                                                    <TextBlock HorizontalAlignment="Right" Style="{StaticResource SubtleBodyStyle}" Text="{Binding ShareText}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Padding="20" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="최근 지출 거래" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="비용 계정으로 분류된 최근 거래를 모아 보여줍니다." TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Row="2" Background="{DynamicResource PanelRaisedBrush}" CornerRadius="18">
                            <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowStyle="{StaticResource RecentTransactionRowStyle}" HeadersVisibility="Column" ItemsSource="{Binding RecentExpenseEntries}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="110" Header="날짜" Binding="{Binding EntryDate, StringFormat=yyyy-MM-dd}" />
                                    <DataGridTextColumn Width="180" Header="거래명" Binding="{Binding Description}" />
                                    <DataGridTextColumn Width="170" Header="지출 계정" Binding="{Binding ToAccountName}" />
                                    <DataGridTextColumn Width="120" Header="결제 계정" Binding="{Binding FromAccountName}" />
                                    <DataGridTextColumn Width="120" Header="금액" Binding="{Binding Amount, StringFormat={}{0:N0}원}" />
                                    <DataGridTextColumn Width="*" Header="메모" Binding="{Binding Memo}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="4" Visibility="{Binding IsAccountStatusAnalysisTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ItemsControl ItemsSource="{Binding AccountStatusHighlights}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource InsightCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding Title}" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource MetricValueStyle}" Text="{Binding Value}" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource SubtleBodyStyle}" Text="{Binding Hint}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Padding="20" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="주요 계정 밸런스" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="{Binding AccountStatusPeriodDescription}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1" Padding="12,6" Background="{DynamicResource HoverBrush}" CornerRadius="14" VerticalAlignment="Top">
                                <TextBlock HorizontalAlignment="Center"
                                           Style="{StaticResource SubtleBodyStyle}"
                                           Text="{Binding AccountStatusRangeSummary}"
                                           TextAlignment="Center" />
                            </Border>
                        </Grid>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding AccountStatusPeriodOptions}" SelectedItem="{Binding SelectedAccountStatusPeriodOption, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource ComboTemplateTextStyle}" Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource SubtleBodyStyle}" Text="선택 기간 안에 움직임이 있었던 계정을 중심으로 유입과 유출을 보여주고, 마지막 열에서는 현재 잔액을 함께 확인합니다." TextWrapping="Wrap" />
                        </Grid>
                        <Border Grid.Row="4" Background="{DynamicResource PanelRaisedBrush}" CornerRadius="18">
                            <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" ItemsSource="{Binding StatusAccountHighlights}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="60" Header="구분" Binding="{Binding Icon}" />
                                    <DataGridTextColumn Width="160" Header="계정" Binding="{Binding Name}" />
                                    <DataGridTextColumn Width="100" Header="유형" Binding="{Binding TypeLabel}" />
                                    <DataGridTextColumn Width="130" Header="기간 유입" Binding="{Binding IncomingTotal, StringFormat={}{0:N0}원}" />
                                    <DataGridTextColumn Width="130" Header="기간 유출" Binding="{Binding OutgoingTotal, StringFormat={}{0:N0}원}" />
                                    <DataGridTextColumn Width="*" Header="현재 잔액" Binding="{Binding BalanceText}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource PositiveValueBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPositiveBalance}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource NegativeValueBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Padding="20" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="유형별 요약" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="선택 기간에 움직인 계정을 자산, 투자, 부채 같은 큰 분류로 묶어 현재 잔액 기준으로 비교합니다." TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1" Padding="12,6" Background="{DynamicResource HoverBrush}" CornerRadius="14" VerticalAlignment="Top">
                                <TextBlock HorizontalAlignment="Center"
                                           Style="{StaticResource SubtleBodyStyle}"
                                           Text="{Binding AccountStatusRangeSummary}"
                                           TextAlignment="Center" />
                            </Border>
                        </Grid>
                        <TextBlock Grid.Row="2" Style="{StaticResource SubtleBodyStyle}" Text="어느 유형에 잔액이 몰려 있는지, 또 어떤 유형이 최근 더 자주 움직였는지 함께 읽을 수 있습니다." TextWrapping="Wrap" />
                        <ItemsControl Grid.Row="4" ItemsSource="{Binding AccountTypeSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="14,12" Background="{DynamicResource PanelRaisedBrush}" CornerRadius="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding TypeLabel}" />
                                                <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="{Binding AccountCountText}" />
                                                <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="{Binding Description}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource SignedValueTextStyle}" Text="{Binding TotalText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4" Padding="20" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="최근 거래" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleBodyStyle}" Text="최신 순서로 정렬한 전체 거래를 빠르게 확인합니다." TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Row="2" Background="{DynamicResource PanelRaisedBrush}" CornerRadius="18">
                        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowStyle="{StaticResource RecentTransactionRowStyle}" HeadersVisibility="Column" ItemsSource="{Binding JournalEntries}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="140" Header="날짜" Binding="{Binding EntryDate, StringFormat=yyyy-MM-dd}" />
                                <DataGridTextColumn Width="220" Header="거래명" Binding="{Binding Description}" />
                                <DataGridTextColumn Width="260" Header="왼쪽 계정" Binding="{Binding FromAccountName}" />
                                <DataGridTextColumn Width="260" Header="오른쪽 계정" Binding="{Binding ToAccountName}" />
                                <DataGridTextColumn Width="160" Header="금액" Binding="{Binding Amount, StringFormat={}{0:N0}원}" />
                                <DataGridTextColumn Width="*" Header="메모" Binding="{Binding Memo}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
