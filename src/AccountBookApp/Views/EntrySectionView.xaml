<UserControl x:Class="AccountBookApp.Views.EntrySectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MinHeight="1560">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="24"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding EntrySectionTitleText}" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="{Binding EntrySectionDescriptionText}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="18,16"
                            Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="출금 계정" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedFromAccount.DisplayName}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource SubtleBodyStyle}"
                                       Text="{Binding SelectedFromAccount.Description}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="18,16"
                            Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="입금 계정" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedToAccount.DisplayName}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource SubtleBodyStyle}"
                                       Text="{Binding SelectedToAccount.Description}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="출금 계정 선택" />
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding ActiveAccounts}"
                                  SelectedItem="{Binding SelectedFromAccount, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource ComboTemplateTextStyle}" Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="입금 계정 선택" />
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding ActiveAccounts}"
                                  SelectedItem="{Binding SelectedToAccount, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource ComboTemplateTextStyle}" Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="날짜" />
                        <DatePicker Margin="0,8,0,0"
                                    SelectedDate="{Binding EntryDate, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="금액" />
                        <TextBox Margin="0,8,0,0"
                                 Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="3">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="거래명" />
                        <TextBox Margin="0,8,0,0"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.ColumnSpan="3">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="메모" />
                        <TextBox Margin="0,8,0,0"
                                 MinHeight="108"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="6"
                        Padding="14,12"
                        Background="{DynamicResource WarningBackgroundBrush}"
                        BorderBrush="{DynamicResource WarningBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding HasValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Foreground="{DynamicResource WarningTextBrush}"
                               Text="{Binding ValidationMessage}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="148"
                            Height="46"
                            Command="{Binding AddEntryCommand}"
                            Content="{Binding EntrySubmitButtonText}" />

                    <TextBlock Grid.Column="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="{Binding LedgerCountText}" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="24"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="최근 거래" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SubtleBodyStyle}"
                                   Text="입력된 거래를 월 단위로 모아 보고, 수정 버튼을 누르면 별도 창에서 바로 수정할 수 있습니다."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ComboBox Grid.Column="1"
                              Width="164"
                              Margin="12,0,0,0"
                              ItemsSource="{Binding EntryHistoryMonths}"
                              SelectedItem="{Binding SelectedEntryHistoryMonth, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource ComboTemplateTextStyle}"
                                           Text="{Binding StringFormat={}{0:yyyy년 M월}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Border Grid.Column="2"
                            MinWidth="182"
                            Height="44"
                            Margin="12,0,0,0"
                            Padding="14,6"
                            Background="{DynamicResource HoverBrush}"
                            CornerRadius="14"
                            VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SubtleBodyStyle}"
                                    Text="{Binding EntryHistoryRangeSummary}"
                                    TextAlignment="Center" />
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Background="{DynamicResource PanelRaisedBrush}"
                        CornerRadius="18">
                    <DataGrid AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              RowStyle="{StaticResource RecentTransactionRowStyle}"
                              HeadersVisibility="Column"
                              ItemsSource="{Binding FilteredJournalEntries}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="118"
                                                Header="날짜"
                                                Binding="{Binding EntryDate, StringFormat=yyyy-MM-dd}" />
                            <DataGridTextColumn Width="210"
                                                Header="거래명"
                                                Binding="{Binding Description}" />
                            <DataGridTextColumn Width="290"
                                                Header="계정 흐름"
                                                Binding="{Binding FlowText}" />
                            <DataGridTextColumn Width="140"
                                                Header="금액"
                                                Binding="{Binding Amount, StringFormat={}{0:N0}원}" />
                            <DataGridTextColumn Width="*"
                                                Header="메모"
                                                Binding="{Binding Memo}" />
                            <DataGridTemplateColumn Width="148" Header="관리">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                            <Button Style="{StaticResource InlineActionButtonStyle}"
                                                    Click="InlineEditJournalEntryButton_Click"
                                                    Content="수정" />
                                            <Button Margin="8,0,0,0"
                                                    Style="{StaticResource InlineDangerActionButtonStyle}"
                                                    Click="InlineDeleteJournalEntryButton_Click"
                                                    Content="삭제" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Padding="24"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="자동이체" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="반복되는 이체를 미리 등록해 두고, 어떤 자동이체가 예정되어 있는지 바로 확인할 수 있습니다."
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.ColumnSpan="3"
                            Padding="14,12"
                            Background="{DynamicResource InfoBackgroundBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource AccentBodyStyle}" Text="자동이체 설정" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="{Binding AutoTransferEditSummaryText}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="출금 계정" />
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding ActiveAccounts}"
                                  SelectedItem="{Binding SelectedAutoTransferFromAccount, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource ComboTemplateTextStyle}" Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="입금 계정" />
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding ActiveAccounts}"
                                  SelectedItem="{Binding SelectedAutoTransferToAccount, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource ComboTemplateTextStyle}" Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="4">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="이체일" />
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding AutoTransferDayOptions}"
                                  SelectedItem="{Binding SelectedAutoTransferDay, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource ComboTemplateTextStyle}"
                                               Text="{Binding StringFormat=매월 {0}일}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="금액" />
                        <TextBox Margin="0,8,0,0"
                                 Text="{Binding AutoTransferAmountText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.ColumnSpan="3">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="자동이체 이름" />
                        <TextBox Margin="0,8,0,0"
                                 Text="{Binding AutoTransferDescription, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,16,0,0"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="메모" />
                        <TextBox Margin="0,8,0,0"
                                 MinHeight="92"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding AutoTransferMemo, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="4"
                        Padding="14,12"
                        Background="{DynamicResource WarningBackgroundBrush}"
                        BorderBrush="{DynamicResource WarningBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding HasAutoTransferValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Foreground="{DynamicResource WarningTextBrush}"
                               Text="{Binding AutoTransferValidationMessage}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="156"
                            Height="46"
                            Command="{Binding SaveAutoTransferCommand}"
                            Content="{Binding AutoTransferSubmitButtonText}" />

                    <Button Grid.Column="1"
                            Width="120"
                            Height="46"
                            Margin="10,0,0,0"
                            Background="{DynamicResource SecondaryButtonBrush}"
                            BorderBrush="{DynamicResource SecondaryButtonBorderBrush}"
                            Foreground="{DynamicResource SecondaryButtonTextBrush}"
                            Command="{Binding CancelAutoTransferEditCommand}"
                            Content="취소"
                            Visibility="{Binding IsAutoTransferEditMode, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <TextBlock Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Style="{StaticResource SubtleBodyStyle}"
                               Text="{Binding AutoTransferCountText}" />
                </Grid>

                <Border Grid.Row="8"
                        Background="{DynamicResource PanelRaisedBrush}"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="16,16,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="등록된 자동이체" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SubtleBodyStyle}"
                                           Text="등록된 규칙을 확인하고, 필요한 항목만 수정하거나 삭제할 수 있습니다."
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    MinWidth="204"
                                    Padding="14,6"
                                    Background="{DynamicResource HoverBrush}"
                                    CornerRadius="14"
                                    VerticalAlignment="Top">
                                <TextBlock HorizontalAlignment="Center"
                                           Style="{StaticResource SubtleBodyStyle}"
                                           Text="{Binding AutoTransferCountText}"
                                           TextAlignment="Center" />
                            </Border>
                        </Grid>

                        <DataGrid Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  ItemsSource="{Binding AutoTransferRules}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="112"
                                                    Header="이체일"
                                                    Binding="{Binding TransferDayText}" />
                                <DataGridTextColumn Width="190"
                                                    Header="자동이체명"
                                                    Binding="{Binding Description}" />
                                <DataGridTextColumn Width="290"
                                                    Header="계정 흐름"
                                                    Binding="{Binding FlowText}" />
                                <DataGridTextColumn Width="122"
                                                    Header="금액"
                                                    Binding="{Binding AmountText}" />
                                <DataGridTextColumn Width="132"
                                                    Header="다음 예정일"
                                                    Binding="{Binding NextScheduledDateText}" />
                                <DataGridTextColumn Width="*"
                                                    Header="메모"
                                                    Binding="{Binding Memo}" />
                                <DataGridTemplateColumn Width="148" Header="관리">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal">
                                                <Button Style="{StaticResource InlineActionButtonStyle}"
                                                        Click="InlineEditAutoTransferButton_Click"
                                                        Content="수정" />
                                                <Button Margin="8,0,0,0"
                                                        Style="{StaticResource InlineDangerActionButtonStyle}"
                                                        Click="InlineDeleteAutoTransferButton_Click"
                                                        Content="삭제" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
