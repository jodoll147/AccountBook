<Window x:Class="AccountBookApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:AccountBookApp.Views"
        mc:Ignorable="d"
        Title="가계부"
        Width="1520"
        Height="980"
        MinWidth="1380"
        MinHeight="900"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="28">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="32" Height="32" Background="{DynamicResource AccentBrush}" CornerRadius="16">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Text="AB" />
                            </Border>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="가계부" />
                                <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="대시보드" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Button Command="{Binding ShowAnalysisSectionCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAnalysisSectionSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Text="O" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold" Text="분석" />
                                    <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="자산·지출 그래프" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Margin="0,8,0,0" Command="{Binding ShowEntrySectionCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEntrySectionSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Text="+" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold" Text="입력" />
                                    <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="거래 추가" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Margin="0,8,0,0" Command="{Binding ShowSettingsSectionCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSettingsSectionSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Text="=" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold" Text="설정" />
                                    <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="계정 관리" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <Button Grid.Row="3" Command="{Binding OpenUserProfileCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                <Setter Property="Padding" Value="12" />
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="{DynamicResource HoverBrush}" CornerRadius="16">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Text="{Binding UserProfileAvatarText}" />
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding UserProfileName}" />
                                <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="{Binding LedgerName}" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource PaperBackgroundBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="28">
                <ScrollViewer x:Name="MainContentScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PreviewMouseWheel="MainContentScrollViewer_PreviewMouseWheel">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Style="{StaticResource SubtleBodyStyle}" Text="{Binding SectionBreadcrumbText}" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource DisplayTitleStyle}"
                                           Text="{Binding SectionTitleText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SubtleBodyStyle}"
                                           Text="{Binding SectionSummaryText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                        </Grid>

                        <ItemsControl Grid.Row="2" AlternationCount="4" ItemsSource="{Binding Metrics}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,16,0" Padding="20,16" CornerRadius="20">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                 Value="0">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel x:Name="MetricTextHost"
                                                        TextElement.Foreground="{DynamicResource SecondaryButtonTextBrush}">
                                                <TextBlock x:Name="MetricTitleText"
                                                           FontSize="13"
                                                           Text="{Binding Title}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           x:Name="MetricValueText"
                                                           FontSize="30"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Value}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           x:Name="MetricHintText"
                                                           Text="{Binding Hint}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    x:Name="MetricBadge"
                                                    Width="28"
                                                    Height="28"
                                                    Background="{DynamicResource HoverBrush}"
                                                    CornerRadius="14">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           x:Name="MetricBadgeText"
                                                           Foreground="{DynamicResource SecondaryButtonTextBrush}"
                                                           Text="~" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                     Value="0">
                                            <Setter TargetName="MetricTextHost" Property="TextElement.Foreground" Value="{DynamicResource AccentTextBrush}" />
                                            <Setter TargetName="MetricBadgeText" Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="4">
                            <views:EntrySectionView Visibility="{Binding IsEntrySectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <views:AnalysisSectionView Visibility="{Binding IsAnalysisSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <views:SettingsSectionView Visibility="{Binding IsSettingsSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <views:AccountPopupView />
        <views:UserProfilePopupView />
    </Grid>
</Window>
