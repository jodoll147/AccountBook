<Application x:Class="AccountBookApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:AccountBookApp.Models"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <FontFamily x:Key="AppFontFamily">Malgun Gothic</FontFamily>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#262626" />
        <SolidColorBrush x:Key="PaperBackgroundBrush" Color="#303030" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#353535" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#474747" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#2C2C2C" />
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#303030" />
        <SolidColorBrush x:Key="HeaderMutedBrush" Color="#404040" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#BCC7D3" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#93A2AF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4DA3FF" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#BE5AF2" />
        <SolidColorBrush x:Key="PositiveValueBrush" Color="#FF6B6B" />
        <SolidColorBrush x:Key="NegativeValueBrush" Color="#4DA3FF" />
        <SolidColorBrush x:Key="ChipBackgroundBrush" Color="#414141" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#3B3B3B" />
        <SolidColorBrush x:Key="InputSurfaceBrush" Color="#3B3B3B" />
        <SolidColorBrush x:Key="InputContrastTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CalendarSurfaceBrush" Color="#303030" />
        <SolidColorBrush x:Key="CalendarTextBrush" Color="#17303C" />
        <SolidColorBrush x:Key="CalendarMutedBrush" Color="#8D8D8D" />
        <SolidColorBrush x:Key="LineBrush" Color="#3F3F3F" />
        <SolidColorBrush x:Key="HoverBrush" Color="#4A4A4A" />
        <SolidColorBrush x:Key="WarningTextBrush" Color="#F6C1B3" />
        <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#3B2021" />
        <SolidColorBrush x:Key="WarningBorderBrush" Color="#70403C" />
        <SolidColorBrush x:Key="InfoBackgroundBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#464646" />
        <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#525252" />
        <SolidColorBrush x:Key="SecondaryButtonTextBrush" Color="#F5F5F5" />
        <SolidColorBrush x:Key="TabIdleBackgroundBrush" Color="#353535" />
        <SolidColorBrush x:Key="TabActiveBackgroundBrush" Color="#3F3F3F" />
        <SolidColorBrush x:Key="ChartGridBrush" Color="#444444" />
        <SolidColorBrush x:Key="NetAssetLineBrush" Color="#BE5AF2" />
        <SolidColorBrush x:Key="ExpenseLineBrush" Color="#4DA3FF" />

        <Style x:Key="PaperCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PaperBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource PaperCardStyle}">
            <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>

        <Style x:Key="SidebarTileStyle" TargetType="Border" BasedOn="{StaticResource PaperCardStyle}">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="SidebarMenuItemStyle" TargetType="Border" BasedOn="{StaticResource PaperCardStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,10" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="DisplayTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="21" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SubtleBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="LineHeight" Value="21" />
        </Style>

        <Style x:Key="AccentBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource AccentStrongBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ComboTemplateTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=Foreground}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ComboBoxItem}, Path=IsEnabled}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource InputContrastTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ComboBoxItem}, Path=IsEnabled}" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource CalendarMutedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Window">
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HasDropShadow" Value="False" />
        </Style>

        <Style TargetType="Control">
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="44" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource InputContrastTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="34" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Margin="12,0,8,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      RecognizesAccessKey="True"
                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  FocusVisualStyle="{x:Null}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="ArrowHost"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="0,14,14,0">
                                                    <Path Width="10"
                                                          Height="6"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Fill="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=Foreground}"
                                                          Data="M 0 0 L 10 0 L 5 6 Z" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ArrowHost" Property="Background" Value="{DynamicResource HoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="ArrowHost" Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="{DynamicResource InputSurfaceBrush}"
                                            BorderBrush="{DynamicResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6" />
                                    <ScrollViewer Margin="4"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="ComboBorder" Property="MinHeight" Value="36" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DatePickerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
            <Setter Property="Background" Value="#F0A83A" />
            <Setter Property="BorderBrush" Value="{DynamicResource CalendarTextBrush}" />
            <Setter Property="BorderThickness" Value="1,0,0,0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,14,14,0">
                            <Grid Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Margin="1,3,1,1"
                                        BorderBrush="{TemplateBinding Foreground}"
                                        BorderThickness="1"
                                        CornerRadius="3" />
                                <Border Height="4"
                                        VerticalAlignment="Top"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="2" />
                                <Rectangle Width="2"
                                           Height="4"
                                           Margin="3,0,0,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           Fill="{TemplateBinding Background}" />
                                <Rectangle Width="2"
                                           Height="4"
                                           Margin="0,0,3,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top"
                                           Fill="{TemplateBinding Background}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFC96B" />
                                <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#D8911F" />
                                <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="{DynamicResource InputContrastTextBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource InputContrastTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0,10,0" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid SnapsToDevicePixels="True"
                              TextElement.Foreground="{TemplateBinding Foreground}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          HorizontalScrollBarVisibility="Hidden"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          VerticalScrollBarVisibility="Hidden" />
                            <ContentControl x:Name="PART_Watermark"
                                            Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            IsHitTestVisible="False"
                                            Visibility="Collapsed" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DatePicker">
            <EventSetter Event="Loaded" Handler="DatePickerLoaded" />
            <Setter Property="Foreground" Value="{DynamicResource InputContrastTextBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource InputContrastTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid>
                            <Border x:Name="DatePickerBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>
                                    <DatePickerTextBox x:Name="PART_TextBox"
                                                       Grid.Column="0"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       HorizontalContentAlignment="Stretch"
                                                       TextElement.Foreground="{TemplateBinding Foreground}"
                                                       VerticalContentAlignment="Center"
                                                       CaretBrush="{DynamicResource TextPrimaryBrush}" />
                                    <Button x:Name="PART_Button"
                                            Grid.Column="1"
                                            Style="{StaticResource DatePickerButtonStyle}"
                                            Background="#F0A83A"
                                            BorderBrush="{DynamicResource CalendarTextBrush}"
                                            Foreground="{DynamicResource CalendarTextBrush}" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border Margin="0,8,0,0"
                                        Padding="12"
                                        Background="{DynamicResource CalendarSurfaceBrush}"
                                        BorderBrush="{DynamicResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Calendar x:Name="PART_Calendar"
                                              Background="{DynamicResource CalendarSurfaceBrush}"
                                              BorderThickness="0"
                                              CalendarButtonStyle="{DynamicResource DatePickerCalendarButtonStyle}"
                                              CalendarDayButtonStyle="{DynamicResource DatePickerCalendarDayButtonStyle}"
                                              CalendarItemStyle="{DynamicResource DatePickerCalendarItemStyle}"
                                              DisplayDateChanged="CalendarPopupDisplayDateChanged"
                                              DisplayModeChanged="CalendarPopupDisplayModeChanged"
                                              Foreground="{DynamicResource CalendarTextBrush}"
                                              Loaded="CalendarPopupLoaded"
                                              TextElement.Foreground="{DynamicResource CalendarTextBrush}" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DatePickerBorder" Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="DatePickerBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DatePickerBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                            <Trigger SourceName="PART_Button" Property="IsMouseOver" Value="True">
                                <Setter TargetName="DatePickerBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource InputContrastTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF3F6" />
                                <Setter Property="Foreground" Value="#17303C" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E3EDF3" />
                                <Setter Property="Foreground" Value="#17303C" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource CalendarMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Calendar">
            <Setter Property="Background" Value="{DynamicResource CalendarSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource CalendarTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Style.Resources>
                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Style>
                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Style>
                <Style TargetType="CalendarButton">
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Style>
                <Style TargetType="CalendarDayButton">
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Style>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFF" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#17303C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFFFFF" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#17303C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#17303C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InfoTextBrushKey}" Color="#17303C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveCaptionTextBrushKey}" Color="#7E909D" />
                <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#8D8D8D" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ActiveBorderBrushKey}" Color="#3F3F3F" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveBorderBrushKey}" Color="#3F3F3F" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4DA3FF" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#17303C" />
            </Style.Resources>
        </Style>

        <Style TargetType="CalendarDayButton">
            <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Border x:Name="DayBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <TextBlock x:Name="DayText"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                       Foreground="{DynamicResource CalendarTextBrush}"
                                       Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter TargetName="DayBorder" Property="Opacity" Value="0.42" />
                                <Setter TargetName="DayText" Property="Foreground" Value="{DynamicResource CalendarMutedBrush}" />
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="DayBorder" Property="BorderThickness" Value="1" />
                                <Setter TargetName="DayText" Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="#D7F5FF" />
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="#7AD7F0" />
                                <Setter TargetName="DayText" Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="#EAF6FA" />
                                <Setter TargetName="DayText" Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsInactive" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource CalendarMutedBrush}" />
                </Trigger>
                <Trigger Property="IsToday" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3EDF3" />
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2F5F7" />
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DatePickerCalendarDayButtonStyle"
               TargetType="CalendarDayButton"
               BasedOn="{StaticResource {x:Type CalendarDayButton}}" />

        <Style TargetType="CalendarButton">
            <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarButton">
                        <Border x:Name="CalendarButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <TextBlock x:Name="CalendarButtonText"
                                       Margin="{TemplateBinding Padding}"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                       Foreground="{DynamicResource CalendarTextBrush}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter TargetName="CalendarButtonBorder" Property="Opacity" Value="0.45" />
                                <Setter TargetName="CalendarButtonText" Property="Foreground" Value="{DynamicResource CalendarMutedBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CalendarButtonBorder" Property="Background" Value="#F2F5F7" />
                                <Setter TargetName="CalendarButtonText" Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CalendarButtonBorder" Property="Background" Value="#E3EDF3" />
                                <Setter TargetName="CalendarButtonText" Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2F5F7" />
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E3EDF3" />
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DatePickerCalendarButtonStyle"
               TargetType="CalendarButton"
               BasedOn="{StaticResource {x:Type CalendarButton}}" />

        <Style x:Key="DatePickerCalendarItemStyle" TargetType="{x:Type primitives:CalendarItem}">
            <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource CalendarTextBrush}" />
            <Style.Resources>
                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Style>
                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                    <Setter Property="Foreground" Value="{DynamicResource CalendarTextBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource CalendarTextBrush}" />
                </Style>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#17303C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#17303C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#17303C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InfoTextBrushKey}" Color="#17303C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#17303C" />
            </Style.Resources>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="InlineDangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource InlineActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource WarningBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource WarningBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource TabIdleBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TabActiveBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource PaperBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource PaperBackgroundBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="52" />
            <Setter Property="ColumnHeaderHeight" Value="44" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border x:Name="CellBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CellBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="CellBorder" Property="BorderThickness" Value="0,2,0,2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="48" />
        </Style>

        <Style x:Key="RecentTransactionRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource PaperBackgroundBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TransactionKind}" Value="{x:Static models:JournalEntryKind.Expense}">
                    <Setter Property="Background" Value="#3A2327" />
                    <Setter Property="Foreground" Value="#FFC2C9" />
                </DataTrigger>
                <DataTrigger Binding="{Binding TransactionKind}" Value="{x:Static models:JournalEntryKind.Transfer}">
                    <Setter Property="Background" Value="#3A341F" />
                    <Setter Property="Foreground" Value="#F4D576" />
                </DataTrigger>
                <DataTrigger Binding="{Binding TransactionKind}" Value="{x:Static models:JournalEntryKind.Revenue}">
                    <Setter Property="Background" Value="#1E3048" />
                    <Setter Property="Foreground" Value="#9FD1FF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Application.Resources>
</Application>

